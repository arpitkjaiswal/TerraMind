# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Aegis
APP_ENV=development          # development | staging | production
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_USE_openssl_rand_-hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aegis
POSTGRES_USER=aegis_user
POSTGRES_PASSWORD=aegis_secret
DATABASE_URL=postgresql+asyncpg://aegis_user:aegis_secret@localhost:5432/aegis

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_secret
NEO4J_DATABASE=neo4j

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=                # leave blank for local unauthenticated
QDRANT_COLLECTION_PREFIX=aegis_

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL_SECONDS=3600
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.92

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Object storage (S3-compatible) ────────────────────────────────────────────
S3_BUCKET=aegis-documents
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=              # set for MinIO / local; blank for AWS

# ── LLM providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_PRIMARY=anthropic         # anthropic | openai
LLM_MODEL=claude-3-5-sonnet-20241022

# ── Azure AI Document Intelligence (OCR) ──────────────────────────────────────
AZURE_FORM_RECOGNIZER_ENDPOINT=
AZURE_FORM_RECOGNIZER_KEY=

# ── Google Cloud Vision (OCR fallback) ────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=

# ── Cognee ────────────────────────────────────────────────────────────────────
COGNEE_LLM_PROVIDER=anthropic
COGNEE_EMBEDDING_MODEL=text-embedding-3-small
COGNEE_GRAPH_DATABASE_PROVIDER=neo4j
COGNEE_VECTOR_DATABASE_PROVIDER=qdrant

# ── OCR confidence thresholds ─────────────────────────────────────────────────
OCR_AUTO_INGEST_THRESHOLD=0.85
OCR_REJECT_THRESHOLD=0.40

# ── Observability ─────────────────────────────────────────────────────────────
OTLP_ENDPOINT=http://localhost:4317
SENTRY_DSN=
PROMETHEUS_METRICS_ENABLED=true

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_QUERY=20/minute
RATE_LIMIT_INGEST=10/minute

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── SSRF allow-list (weather APIs etc.) ──────────────────────────────────────
ALLOWED_OUTBOUND_DOMAINS=api.open-meteo.com,openweathermap.org,api.weather.gov
